{
  "$schema": "https://turborepo.dev/schema.json",
  "ui": "tui",
  "tasks": {
    "build": {
      "dependsOn": ["^build"],
      "inputs": ["$TURBO_DEFAULT$", ".env*"],
      "outputs": [".next/**", "!.next/cache/**"]
    },
    
    "test": {
      "dependsOn": ["^build"],
      "env": [
        "DATABASE_URL",
        "GROQ_API_KEY",
        "ENVIRONMENT",
        "POLYGON_AMOY_RPC_URL",
        "VECTOR_DB_NAME",
        "VECTOR_DB_USER",
        "VECTOR_DB_PASSWORD",
        "VECTOR_DB_PORT",
        "ORACLE_PRIVATE_KEY"
      ]
    },
   
    "lint": {
      "dependsOn": ["^lint"]
    },
    "check-types": {
      "dependsOn": ["^check-types"]
    },
    "dev": {
      "cache": false,
      "persistent": true
    }
  }
}
